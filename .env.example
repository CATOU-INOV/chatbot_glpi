# Copier ce fichier en .env et remplir les valeurs réelles.
# .env est gitignored — .env.example sert de doc pour savoir quelles variables déclarer.

# --- Snowflake (source des tickets GLPI) ---
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_DATABASE=DEVELOPMENT
SNOWFLAKE_SCHEMA=TCAT
# Authentification par clé privée (recommandé, requis si MFA actif sur le compte).
# Laisser vide pour retomber sur SNOWFLAKE_PASSWORD.
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# --- Qdrant (base vectorielle, tourne en local via Docker) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=glpi_tickets

# --- Recherche hybride (dense + sparse BM25) ---
# Noms des deux named vectors dans la collection Qdrant — doivent être
# identiques à l'ingestion et à la recherche.
DENSE_VECTOR_NAME=dense
SPARSE_VECTOR_NAME=bm25
SPARSE_MODEL_NAME=Qdrant/bm25

# --- RAG : retrieval hybride (chunks) + reranking (cross-encoder, tickets) ---
RAG_RETRIEVAL_TOP_K=25
RAG_RERANK_TOP_K=3
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
# Longueur minimale de la solution nettoyée pour garder un ticket à l'ingestion.
MIN_SOLUTION_LENGTH=30

# --- Ollama (LLM local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Langfuse (self-host Docker, pas cloud) ---
# Laisser vide pour désactiver le tracing sans casser l'API (mode no-op).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- CORS ---
# "*" en dev uniquement. En prod, restreindre à l'URL exacte de l'instance GLPI.
CORS_ALLOW_ORIGINS=["*"]
